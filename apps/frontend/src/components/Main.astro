---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { candidates, parties, running_positions, event } from "@repo/constants";
import Carousel from "./Carousel.astro";
import MainCard from "./MainCard";
import LogoImg from "@/assets/logo-black.png";
import BoxImg from "@/pics/main/BoxIcon.webp";
import LineImg from "@/pics/main/line.webp";

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/*.{jpg,jpeg,png,webp}",
	{ eager: true },
);

const candidatesWithImages = await Promise.all(
	candidates.map(async (candidate) => {
		const filename = candidate.image ?? "";
		const key = `../assets${filename}`;
		const mod = imageModules[key];
		let imageSrc = "";
		if (mod?.default) {
			const optimized = await getImage({ src: mod.default, format: "webp" });
			imageSrc = optimized.src;
		}
		return { ...candidate, imageSrc };
	}),
);

const [logo, boxIcon, line] = await Promise.all([
	getImage({ src: LogoImg }),
	getImage({ src: BoxImg }),
	getImage({ src: LineImg }),
]);
---

<MainCard
  client:load
  candidatesWithImages={candidatesWithImages}
  parties={parties}
  positions={running_positions}
  eventName={event.full_name}
  votingStartString={event.votingStartString}
  votingEndString={event.votingEndString}
  logoSrc={logo.src}
  boxIconSrc={boxIcon.src}
  lineSrc={line.src}
/>
