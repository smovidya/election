---
import { Image } from "astro:assets";
import BigBox from "@/pics/finish/BigBox.webp";
import Logo from "@/assets/logo-color-light.png";
import download from "@/pics/finish/download.webp";
import link from "@/pics/finish/link.webp";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div
    id="captureArea"
    class="w-full min-h-screen bg-white flex justify-center"
  >
    <div class="w-[390px] flex flex-col items-center justify-center px-4 py-6">
      <Image src={Logo} alt={"logo"} class="w-40 my-2" />

      <div
        class="font-noto mb-7 font-medium text-pink text-lg text-center whitespace-pre-line"
      >
        <h class="leading-relaxed text-pink-500">
          คุณได้ลงคะแนนเสียง เสร็จสิ้นเป็นที่เรียบร้อยแล้ว
        </h>
      </div>

      <Image src={BigBox} alt={"bigbox"} class="w-25 my-2" />

      <div
        class="font-noto font-medium text-black text-md text-center whitespace-pre-line my-5 leading-relaxed"
      >
        <h>
          ขอขอบคุณที่ร่วมเป็นส่วนหนึ่งในการลงคะแนนเสียง
          เลือกตั้งคณะกรรมการบริหารสโมสรนิสิต คณะวิทยาศาสตร์
          จุฬาลงกรณ์มหาวิทยาลัย ประจำปีการศึกษา 2568
        </h>
      </div>

      <div id="buttonGroup" class="flex flex-row gap-3 my-3">
        <button
          id="screenshotBtn"
          class="bg-yellow py-3 rounded-2xl shadow-lg inline-flex items-center gap-2 px-10"
        >
          <Image src={link} alt={"share"} class="w-5" />
          <h1 class="font-medium font-noto text-base text-brown">แชร์</h1>
        </button>
      </div>

      <div
        class="font-noto font-normal text-dgray text-sm text-center whitespace-pre-line my-3 leading-loose"
      >
        <h>
          สามารถติดตามผลการเลือกตั้งได้ที่ Instagram : smovidya_official และ
          Facebook : สโมสรนิสิตคณะวิทยาศาสตร์ จุฬาลงกรณ์มหาวิทยาลัย - CU
          Smovidya
        </h>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const screenshotBtn = document.getElementById("screenshotBtn");
    const buttonGroup = document.getElementById("buttonGroup");

    const hideButtons = () => {
      if (buttonGroup) buttonGroup.style.display = "none";
    };

    const showButtons = () => {
      if (buttonGroup) buttonGroup.style.display = "flex";
    };

    const stripUnsupportedColors = () => {
      document.querySelectorAll("*").forEach((el) => {
        const computedStyle = getComputedStyle(el);
        ["color", "background-color", "border-color"].forEach((prop) => {
          const value = computedStyle.getPropertyValue(prop);
          if (value.includes("oklch") && el instanceof HTMLElement) {
            el.style.setProperty(prop, "#000", "important");
          }
        });
      });
    };

    const loadHtml2Canvas = async () => {
      try {
        const module = await import("html2canvas");
        return module.default;
      } catch (error) {
        console.error("Failed to load html2canvas:", error);
        throw new Error("Failed to load screenshot library");
      }
    };

    const captureScreenshot = async () => {
        try {
            hideButtons();
            const captureArea = document.getElementById("captureArea");
            if (!captureArea) throw new Error("Capture area not found");

            await document.fonts.ready;
            stripUnsupportedColors();

            // Force white on everything
            captureArea.style.backgroundColor = "#ffffff";
            document.body.style.backgroundColor = "#ffffff";
            document.documentElement.style.backgroundColor = "#ffffff";

            await new Promise((resolve) => setTimeout(resolve, 300));

            const html2canvas = await loadHtml2Canvas();
            const canvas = await html2canvas(captureArea, {
            backgroundColor: "#ffffff",
            useCORS: true,
            scale: 2,
            logging: false,
            allowTaint: true,
            onclone: (clonedDoc) => {
                const clonedArea = clonedDoc.getElementById("captureArea");
                if (clonedArea) {
                clonedArea.style.setProperty("background-color", "#ffffff", "important");
                }
                clonedDoc.body.style.setProperty("background-color", "#ffffff", "important");
                clonedDoc.documentElement.style.setProperty("background-color", "#ffffff", "important");
            },
            });

            showButtons();
            return canvas;
        } catch (error) {
            showButtons();
            console.error("Screenshot error:", error);
            throw error;
        }
    };

    if (screenshotBtn) {
      screenshotBtn.addEventListener("click", async () => {
        try {
          const canvas = await captureScreenshot();

          // แปลง canvas → Blob
          const blob = await new Promise<Blob>((resolve, reject) =>
            canvas.toBlob(
              (b) => (b ? resolve(b) : reject(new Error("Blob failed"))),
              "image/png"
            )
          );

          const file = new File([blob], "voting-receipt.png", {
            type: "image/png",
          });

          // ถ้า browser รองรับ Web Share API + share ไฟล์ได้
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({
              title: "ผลการลงคะแนนเสียง",
              text: "ฉันได้ลงคะแนนเสียงเลือกตั้งสโมสรนิสิตคณะวิทยาศาสตร์ จุฬาฯ เรียบร้อยแล้ว!",
              files: [file],
            });
          } else {
            // Fallback: ดาวน์โหลดปกติถ้า browser ไม่รองรับ
            const url = canvas.toDataURL("image/png");
            const a = document.createElement("a");
            a.href = url;
            a.download = "voting-receipt.png";
            a.click();
          }
        } catch (error: any) {
          // ผู้ใช้กด cancel ไม่ต้องแสดง error
          if (error?.name !== "AbortError") {
            alert("เกิดข้อผิดพลาด กรุณาลองใหม่อีกครั้ง");
          }
        }
      });
    }
  });
</script>
