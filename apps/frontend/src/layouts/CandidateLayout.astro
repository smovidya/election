---
import Layout from "./Layout.astro";
import CandidateCard from "@/components/CandidateCard";
import type { Candidate, Position, Party } from "@repo/constants";

interface Props {
	candidate: Candidate;
	position: Position;
	imageSrc?: string;
	parties?: Party;
}

const { candidate, position, imageSrc, parties } = Astro.props;
---

<Layout>
  <CandidateCard
    candidate={candidate}
    position={position}
    imageSrc={imageSrc}
    party={parties}
    client:load
  />
  <slot />
</Layout>
