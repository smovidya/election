---
import Layout from "./Layout.astro";
import CandidateCard from "@/components/CandidateCard";
import type { Candidate, Position } from "@repo/constants";

interface Props {
  candidate: Candidate;
  position: Position;
  imageSrc?: string;
}

const { candidate, position, imageSrc } = Astro.props;
---

<Layout>
  <CandidateCard
    candidate={candidate}
    position={position}
    imageSrc={imageSrc}
    client:load
  />
  <slot />
</Layout>
